// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Existing models (kept for RSS news) ───────────────────────────

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  samples   Sample[]
}

model Sample {
  id           String        @id @default(uuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       String        @default("healthy") // healthy, warning, critical
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  measurements Measurement[]
}

model Measurement {
  id        String   @id @default(uuid())
  sampleId  String
  sample    Sample   @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  metric    String
  value     Float
  unit      String?
  timestamp DateTime @default(now())
}

// ─── Branch & User models ──────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  incidentReports  IncidentReport[]
  attendanceRecords AttendanceRecord[]
  trainings        Training[]
  simulations      Simulation[]
  mockDrills       MockDrill[]
  inventories      Inventory[]
  moduleConfigs    BranchModuleConfig[]
}

enum UserRole {
  ADMIN
  INPUTTER
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String?  @unique // Separate username field for login (optional for backward compat)
  email     String   @unique
  password  String   // bcrypt hashed
  role      UserRole
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // For tracking who created records
  createdIncidentReports  IncidentReport[]
  createdAttendanceRecords AttendanceRecord[]
  createdTrainings        Training[]
  createdSimulations      Simulation[]
  createdMockDrills       MockDrill[]
  createdInventories      Inventory[]

  // For tracking edits to incident reports
  incidentReportEdits    IncidentReportEdit[]
}

// ─── Data models ───────────────────────────────────────────────────

model IncidentReport {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title       String
  description String
  severity    String   @default("low") // low, medium, high, critical
  date        DateTime
  location    String?
  status      String   @default("open") // open, investigating, resolved, closed
  reportedById String
  reportedBy  User     @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  edits IncidentReportEdit[]
}

model IncidentReportEdit {
  id               String    @id @default(uuid())
  incidentReportId String
  incidentReport   IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)
  editedById       String
  editedBy         User       @relation(fields: [editedById], references: [id], onDelete: Cascade)
  fieldName        String     // e.g. "title", "description", "severity", "status", "location"
  oldValue         String?
  newValue         String?
  editedAt         DateTime   @default(now())
}

model AttendanceRecord {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employeeName String
  date         DateTime
  status       String   @default("present") // present, absent, late, leave
  notes        String?
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Training {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  date         DateTime
  duration     String?  // e.g. "2 hours"
  participants Int      @default(0)
  trainer      String?
  status       String   @default("scheduled") // scheduled, completed, cancelled
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Simulation {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  date         DateTime
  participants Int      @default(0)
  scenario     String?
  result       String?  // pass, fail, partial
  notes        String?
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MockDrill {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  date         DateTime
  participants Int      @default(0)
  drillType    String?  // fire, evacuation, earthquake, etc.
  result       String?  // pass, fail, partial
  notes        String?
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inventory {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  itemName     String
  quantity     Int      @default(0)
  unit         String   @default("pcs")
  category     String?  // equipment, supplies, safety, etc.
  status       String   @default("available") // available, low, out_of_stock
  lastUpdated  DateTime @default(now())
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Custom Field Configuration ────────────────────────────────────

model BranchModuleConfig {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  module    String   // e.g. "incidents", "attendance", "trainings", "inventory", etc.
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customFields CustomField[]

  @@unique([branchId, module])
}

model CustomField {
  id               String   @id @default(uuid())
  moduleConfigId   String
  moduleConfig     BranchModuleConfig @relation(fields: [moduleConfigId], references: [id], onDelete: Cascade)
  fieldName        String   // e.g. "customField1", "notes2", etc.
  fieldLabel       String   // e.g. "Custom Note", "Additional Info", etc.
  fieldType        String   // "text", "textarea", "number", "date", "select"
  isRequired       Boolean  @default(false)
  options          String?  // JSON array for select fields: ["option1", "option2"]
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
