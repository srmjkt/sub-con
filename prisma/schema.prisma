// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Existing models (kept for RSS news) ───────────────────────────

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  samples   Sample[]
}

model Sample {
  id           String        @id @default(uuid())
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       String        @default("healthy") // healthy, warning, critical
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  measurements Measurement[]
}

model Measurement {
  id        String   @id @default(uuid())
  sampleId  String
  sample    Sample   @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  metric    String
  value     Float
  unit      String?
  timestamp DateTime @default(now())
}

// ─── Branch & User models ──────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  incidentReports  IncidentReport[]
  attendanceRecords AttendanceRecord[]
  trainings        Training[]
  simulations      Simulation[]
  mockDrills       MockDrill[]
  inventories      Inventory[]
  moduleConfigs    BranchModuleConfig[]
  employees        Employee[]
}

enum UserRole {
  ADMIN
  INPUTTER
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String?  @unique
  email     String   @unique
  password  String   // bcrypt hashed
  role      UserRole
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchAccess Json?  // { "type": "all" | "custom" | "single", "branchIds": string[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdIncidentReports  IncidentReport[]
  createdAttendanceRecords AttendanceRecord[]
  createdTrainings        Training[]
  createdSimulations      Simulation[]
  createdMockDrills       MockDrill[]
  createdInventories      Inventory[]
  incidentReportEdits    IncidentReportEdit[]
  incidentAttachments   IncidentAttachment[]
}

// ─── Employee Management ──────────────────────────────────────────

model Employee {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employeeId      String
  fullName        String
  email           String?
  phone           String?
  department      String?
  position        String?
  joinDate        DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendanceRecords AttendanceRecord[]

  @@unique([branchId, employeeId])
  @@index([branchId, fullName])
  @@index([branchId, isActive])
}

// ─── Data models ───────────────────────────────────────────────────

model IncidentReport {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title       String
  description String
  severity    String   @default("low")
  date        DateTime
  location    String?
  incidentReportNumber String?
  status      String   @default("open")
  reportedById String
  reportedBy  User     @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attachments IncidentAttachment[]
  edits IncidentReportEdit[]
}

model IncidentAttachment {
  id               String    @id @default(uuid())
  incidentReportId String
  incidentReport   IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)
  fileName         String
  filePath         String
  fileType         String
  fileSize         Int
  uploadedById     String
  uploadedBy       User      @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime  @default(now())
}

model IncidentReportEdit {
  id               String    @id @default(uuid())
  incidentReportId String
  incidentReport   IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)
  editedById       String
  editedBy         User       @relation(fields: [editedById], references: [id], onDelete: Cascade)
  fieldName        String
  oldValue         String?
  newValue         String?
  editedAt         DateTime  @default(now())
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employeeName    String
  employeeId      String?
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  date            DateTime
  status          String   @default("present")
  notes           String?
  recordedById    String
  recordedBy      User     @relation(fields: [recordedById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Training {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  date            DateTime
  duration        String?
  participants    Int      @default(0)
  trainer         String?
  status          String   @default("scheduled")
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Simulation {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  date            DateTime
  participants    Int      @default(0)
  scenario        String?
  result          String?
  notes           String?
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MockDrill {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  date            DateTime
  participants    Int      @default(0)
  drillType       String?
  result          String?
  notes           String?
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Inventory {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  itemName        String
  quantity        Int      @default(0)
  unit            String   @default("pcs")
  category        String?
  status          String   @default("available")
  lastUpdated     DateTime @default(now())
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  customFieldsData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Custom Field Configuration ────────────────────────────────────

model BranchModuleConfig {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  module    String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customFields CustomField[]
  @@unique([branchId, module])
}

model CustomField {
  id               String   @id @default(uuid())
  moduleConfigId   String
  moduleConfig     BranchModuleConfig @relation(fields: [moduleConfigId], references: [id], onDelete: Cascade)
  fieldName        String
  fieldLabel       String
  fieldType        String
  isRequired       Boolean  @default(false)
  options          String?
  optionColors     Json?
  order            Int      @default(0)
  colSpan          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}